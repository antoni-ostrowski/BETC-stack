{
  "name": "@packages/convex",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./api": {
      "import": "./convex/functions/_generated/api.js",
      "types": "./convex/functions/_generated/api.d.ts"
    }
  },
  "scripts": {
    "dev": "convex dev",
    "setup": "convex dev --until-success",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "typecheck": "tsc --noEmit",
    "gen": "bunx better-convex codegen && bun run scripts/patch-auth-types.ts"
  },
  "dependencies": {
    "@convex-dev/better-auth": "catalog:",
    "better-auth": "catalog:",
    "better-convex": "catalog:",
    "convex": "catalog:",
    "convex-helpers": "catalog:",
    "effect": "catalog:",
    "fluent-convex": "^0.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  }
}
