{
  "name": "@packages/convex",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./api": {
      "import": "./convex/functions/_generated/api.js",
      "types": "./convex/functions/_generated/api.d.ts"
    }
  },
  "scripts": {
    "dev": "convex dev",
    "setup": "convex dev --until-success",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "typecheck": "tsc --noEmit -p convex/tsconfig.check.json",
    "gen:auth": "bunx @better-auth/cli generate -y --output convex/functions/authSchema.ts --config convex/functions/generated/auth.ts",
    "gen": "bunx better-convex codegen && bun run scripts/patch-auth-types.ts"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.10.13",
    "better-auth": "1.4.9",
    "better-convex": "^0.10.3",
    "convex": "^1.33.1",
    "convex-helpers": "^0.1.114",
    "effect": "^4.0.0-beta.31",
    "fluent-convex": "^0.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.11"
  }
}
