{
  "name": "@packages/convex",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./api": {
      "import": "./convex/_generated/api.js",
      "types": "./convex/_generated/api.d.ts"
    }
  },
  "scripts": {
    "dev": "convex dev",
    "setup": "convex dev --until-success",
    "typecheck": "tsc --noEmit -p convex",
    "auth:gen": "cd convex/betterAuth && bunx @better-auth/cli generate -y --output generatedSchema.ts"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.10.13",
    "better-auth": "1.4.9",
    "@packages/convex": "workspace:*",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.114",
    "effect": "^3.19.19",
    "fluent-convex": "^0.12.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}
