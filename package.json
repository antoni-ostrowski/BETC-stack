{
  "name": "betc-stack",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/**",
      "apps/**"
    ],
    "catalog": {
      "vite-plus": "^0.1.11",
      "effect": "^4.0.0-beta.31",
      "@t3-oss/env-core": "^0.13.10",
      "typescript": "^5.9.3",
      "vite": "^8.0.0",
      "better-auth": "1.4.9",
      "better-convex": "^0.10.3",
      "@convex-dev/better-auth": "^0.10.13",
      "convex": "^1.33.1",
